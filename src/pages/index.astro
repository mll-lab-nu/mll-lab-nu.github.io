---
import Layout from '../layouts/Layout.astro';
import News from '../components/News/News.jsx';
import Swiper from '../components/Swiper/swiper.astro';
import Blob from '../components/Blob/blob.astro';
import Button from '../components/ui/Button.astro';
import SectionHeader from '../components/ui/SectionHeader.astro';
import PublicationList from '../components/PublicationList.astro';
---

<Layout title="MLL Lab — Home">
	<main class="overflow-x-clip bg-background-light">
		<!-- Hero Section -->
		<section class="py-16 md:py-24">
			<div class="container mx-auto px-4">
				<div class="flex flex-col items-center text-center">
					<a
						href="https://ragen-ai.github.io"
						target="_blank"
						rel="noopener"
						class="mb-8 inline-flex items-center gap-2 rounded-full border border-primary-200 bg-primary-50 px-4 py-1.5 text-sm font-medium text-primary-700 transition-colors hover:bg-primary-100"
					>
						<span class="rounded-full bg-primary-600 px-2 py-0.5 text-xs font-semibold text-white">New</span>
						Announcing RAGEN — Training RL Agents · ⭐ 2.7k
						<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="h-4 w-4">
							<path stroke-linecap="round" stroke-linejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5" />
						</svg>
					</a>

					<h1 class="mb-6 font-heading text-4xl font-bold tracking-tight text-secondary-900 md:text-7xl">
						<span class="text-primary-600">MLL</span> Lab
						<br>
						<span class="text-primary-600">M</span>achine <span class="text-primary-600">L</span>earning and <span class="text-primary-600">L</span>anguage
					</h1>

					<p class="mx-auto mb-8 max-w-3xl text-lg font-medium text-secondary-600 md:text-xl">
						We develop intelligent language + X (vision, robotics, etc) models that reason, plan, and interact with the physical world.
					</p>

					<div class="flex flex-col justify-center gap-3 sm:flex-row">
						<Button href="/joinus" variant="primary" size="lg">Join Us</Button>
						<Button href="/publications" variant="outline" size="lg">Publications</Button>
					</div>
				</div>

				<!-- Projects Carousel -->
				<div id="about" class="relative mt-16">
					<Blob />
					<Swiper />
				</div>
			</div>
		</section>

		<!-- News Section -->
		<section id="news" class="bg-secondary-50 py-14">
			<div class="container mx-auto px-4">
				<SectionHeader title="Latest News" centered={true} className="mb-8" titleClassName="text-primary-600" />
				<div class="mx-auto max-w-5xl">
					<div class="rounded-2xl border border-secondary-100 bg-white p-6 shadow-soft md:p-8">
						<News client:load />
					</div>
				</div>
			</div>
		</section>

		<!-- Selected Publications Section -->
		<section id="publications" class="py-14">
			<div class="container mx-auto px-4">
				<SectionHeader title="Selected Publications" centered={true} className="mb-8" titleClassName="text-primary-600" />
				<div class="mx-auto max-w-5xl">
					<PublicationList featuredOnly />
					<div class="pt-8 text-center">
						<a href="/publications" class="inline-flex items-center font-medium text-primary-600 transition-colors hover:text-primary-700">
							View All Publications
							<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="ml-1 h-4 w-4">
								<path stroke-linecap="round" stroke-linejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5" />
							</svg>
						</a>
					</div>
				</div>
			</div>
		</section>
	</main>
</Layout>

<style>
	.blob {
		position: absolute;
		top: 50%;
		left: 50%;
		transform: translate(-50%, -50%);
		z-index: 0;
	}
</style>
