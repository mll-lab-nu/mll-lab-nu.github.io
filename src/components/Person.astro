---
interface Props {
	name: string;
	href: string;
	image_src: string;
	annotation?: string;
}

const { href, name, image_src, annotation } = Astro.props;
const hasLink = typeof href === 'string' && href.trim() !== '';
const Tag = hasLink ? 'a' : 'div';
---

<div id={name} class="group flex flex-col items-center">
	<Tag
		{...(hasLink ? { href, target: '_blank', rel: 'noopener' } : {})}
		class:list={["flex flex-col items-center transition-transform", hasLink && "group-hover:scale-105"]}
	>
		<div class="relative mb-3 h-32 w-32 overflow-hidden rounded-full border-2 border-primary-100 shadow-soft transition-all group-hover:border-primary-300 group-hover:shadow-medium">
			<img src={image_src} alt={name} class="h-full w-full object-cover" />
		</div>
		<h3 class="text-center font-medium text-secondary-900 transition-colors group-hover:text-primary-700">{name}</h3>
		{annotation && <p class="text-center text-xs text-secondary-600">{annotation}</p>}
	</Tag>
</div>
